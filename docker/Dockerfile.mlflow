FROM python:3.11-slim

RUN apt-get update && apt-get install -y --no-install-recommends \
      curl \
      libpq-dev \
      build-essential \
    && rm -rf /var/lib/apt/lists/*

RUN pip install --no-cache-dir \
      "mlflow==2.18.0" \
      "psycopg2-binary==2.9.10" \
      "boto3==1.35.71"

EXPOSE 5000

CMD ["mlflow", "server", "--host", "0.0.0.0", "--port", "5000"]
