# Forge platform — environment configuration.
# Copy to ".env" and adjust. All variables are optional; the defaults shown are
# safe for a local demo. Lock these down for any shared/production deployment.

# ── API security ──────────────────────────────────────────────────────────────

# Optional API key. When set, EVERY /api/* request must present it via
# "X-API-Key: <key>" or "Authorization: Bearer <key>". '/', '/static', '/health'
# and websockets stay open so the UI shell and health checks keep working.
# Leave empty for an open local demo.
FORGE_API_KEY=

# CORS allowlist (comma-separated origins). Default "*" is for local dev only;
# with the wildcard, credentialed CORS is force-disabled to stay spec-compliant.
# In production set an explicit list, e.g. https://app.example.com
FORGE_ALLOWED_ORIGINS=*

# ── Secrets at rest ───────────────────────────────────────────────────────────

# Fernet master key for the secret manager. Generate with:
#   python -c "from cryptography.fernet import Fernet; print(Fernet.generate_key().decode())"
# If unset, a key is generated and persisted under FORGE_SECRET_ROOT/.key (demo).
FORGE_MASTER_KEY=

# Where encrypted secrets + index + audit log live.
FORGE_SECRET_ROOT=./.forge_secrets

# ── Limits / operations ───────────────────────────────────────────────────────

# Max points accepted on any time-series request body (DoS guard).
FORGE_MAX_SERIES_POINTS=200000

# How many finished builds to retain in memory before evicting the oldest.
FORGE_MAX_BUILDS_IN_MEMORY=500

# Root directory for ML model artifacts written/read by the ML endpoints.
FORGE_ARTIFACT_ROOT=/data/models

# Expose internal absolute paths on /health (info-leak; off by default).
FORGE_HEALTH_VERBOSE=false

# ── ML registry (optional) ────────────────────────────────────────────────────

# Point at a running MLflow tracking server to enable experiment logging +
# model registration. Leave unset to run ML without MLflow.
# MLFLOW_TRACKING_URI=http://localhost:5500

# ── Local feature store ───────────────────────────────────────────────────────
FORGE_DUCKDB_PATH=./data/forge.duckdb
